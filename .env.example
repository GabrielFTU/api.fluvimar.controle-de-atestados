# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente.

# Postgres
POSTGRES_DB=atestados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend (.NET API)
ASPNETCORE_ENVIRONMENT=Production

# JWT (autenticação da API). Gere uma chave forte, ex.: openssl rand -base64 48
JWT_ISSUER=api.fluvimar
JWT_AUDIENCE=api.fluvimar.frontend
JWT_SECURITY_KEY=
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=480

# Usuário administrador inicial (criado automaticamente na primeira subida se não houver nenhum usuário)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Origens do frontend autorizadas a chamar a API (CORS), separadas por vírgula.
# Não é usado para requisições do próprio frontend (mesma origem via proxy reverso),
# só serve de proteção extra caso a API seja chamada de outro domínio.
# Ex.: https://rh.fluvimar.com.br
CORS_ALLOWED_ORIGINS=

# URL que o frontend vai usar para chamar a API (fica embutida no build).
# Como o nginx do frontend faz proxy de /api/ para o container "backend",
# em produção atrás de um reverse proxy por domínio isso deve ficar relativo:
API_PUBLIC_URL=/api
