# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente.

# Postgres
POSTGRES_DB=atestados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend (.NET API)
ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=8080

# JWT (autenticação da API). Gere uma chave forte, ex.: openssl rand -base64 48
JWT_ISSUER=api.fluvimar
JWT_AUDIENCE=api.fluvimar.frontend
JWT_SECURITY_KEY=
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=480

# Usuário administrador inicial (criado automaticamente na primeira subida se não houver nenhum usuário)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Origens do frontend autorizadas a chamar a API (CORS), separadas por vírgula.
# Ex.: https://atestados.suaempresa.com.br
CORS_ALLOWED_ORIGINS=

# Frontend (Vite/Nginx)
FRONTEND_PORT=5173

# URL pública da API que o frontend vai chamar (fica embutida no build, então
# precisa apontar para o domínio real da API em produção).
# Ex.: https://api.suaempresa.com.br/api
API_PUBLIC_URL=
