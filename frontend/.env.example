# Copie este arquivo para ".env" e ajuste os valores conforme o ambiente.

# URL base da API. Para backend rodando via docker compose use a porta
# BACKEND_PORT do .env da raiz (ex: http://localhost:8080/api).
# Para backend rodando localmente via "dotnet run" use a porta do
# launchSettings.json (ex: http://localhost:5274/api).
VITE_API_URL=http://localhost:8080/api
